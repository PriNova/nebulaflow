{
    "name": "nebulaflow",
    "displayName": "NebulaFlow Workflow Editor",
    "version": "0.3.0",
    "publisher": "prinova",
    "author": "prinova",
    "repository": {
        "type": "git",
        "url": "https://github.com/PriNova/nebulaflow.git"
    },
    "engines": {
        "vscode": ">=1.90.0",
        "node": ">=22.19.0"
    },
    "main": "dist/src/extension.js",
    "activationEvents": [],
    "contributes": {
        "commands": [
            {
                "command": "nebulaFlow.openWorkflow",
                "title": "NebulaFlow: Open Workflow Editor"
            }
        ],
        "configuration": {
            "title": "NebulaFlow",
            "properties": {
                "nebulaFlow.storageScope": {
                    "type": "string",
                    "enum": [
                        "workspace",
                        "user"
                    ],
                    "enumDescriptions": [
                        "Store workflows and nodes in the current workspace (.nebulaflow)",
                        "Store workflows and nodes in your user folder (global)"
                    ],
                    "default": "user",
                    "description": "Where NebulaFlow stores workflows and custom nodes."
                },
                "nebulaFlow.globalStoragePath": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Absolute path for global storage. If empty, uses your home directory. Content is stored under .nebulaflow/",
                    "scope": "application"
                }
            }
        }
    },
    "scripts": {
        "build:webview": "vite build --config workflow/Web/vite.config.mts",
        "watch:webview": "vite build --watch --config workflow/Web/vite.config.mts --mode development",
        "build:ext": "node scripts/bundle-ext.mjs",
        "watch:ext": "node scripts/bundle-ext.mjs --watch",
        "watch": "node scripts/dev-watch.mjs",
        "typecheck": "tsc -p . && tsc -p workflow/Web/tsconfig.json && tsc -p electron/tsconfig.json --noEmit",
        "biome": "biome check --apply --error-on-warnings .",
        "format": "npm run lint:fix",
        "check": "npm run -s typecheck && npm run -s lint",
        "lint": "node node_modules/eslint/bin/eslint.js .",
        "lint:fix": "node node_modules/eslint/bin/eslint.js . --fix",
        "build": "npm run -s typecheck && npm run -s build:webview && npm run -s build:ext",
        "package:vsix": "npm run -s build && rm -f dist/${npm_package_name}-${npm_package_version}.vsix && vsce package --out dist/${npm_package_name}-${npm_package_version}.vsix",
        "test:subflows": "node tasks/integration/run-subflows-tests.mjs",
        "build:web": "vite build --config web/vite.config.mts",
        "dev:web": "vite --config web/vite.config.mts",
        "dev:bridge": "npx tsx server/bridge-server.ts",
        "start:web": "npx concurrently \"npm run dev:bridge\" \"npm run dev:web\"",
        "build:electron": "tsc -p electron/tsconfig.json",
        "start:electron": "npm run -s build:webview && npm run -s build:electron && electron dist/electron/electron/main/index.js",
        "dev:electron": "tsc -p electron/tsconfig.json && electron dist/electron/electron/main/index.js",
        "pack:electron": "npm run -s build:webview && npm run -s build:electron && electron-builder build",
        "pack:win": "npm run -s build:webview && npm run -s build:electron && node scripts/pack-win.mjs",
        "zip:win": "npm run pack:win && node scripts/zip-win.mjs"
    },
    "build": {
        "appId": "com.prinova.nebulaflow",
        "productName": "NebulaFlow",
        "extraMetadata": {
            "main": "dist/electron/electron/main/index.js"
        },
        "files": [
            "dist/electron/**/*",
            "dist/webviews/**/*",
            "package.json",
            "node_modules/@earendil-works/pi-agent-core/**/*",
            "node_modules/@earendil-works/pi-ai/**/*",
            "node_modules/@earendil-works/pi-coding-agent/**/*"
        ],
        "directories": {
            "output": "dist/release"
        },
        "linux": {
            "target": "AppImage"
        },
        "mac": {
            "target": "dmg"
        },
        "win": {
            "target": "nsis"
        }
    },
    "dependencies": {
        "@earendil-works/pi-agent-core": "0.80.10",
        "@earendil-works/pi-ai": "0.80.10",
        "@earendil-works/pi-coding-agent": "0.80.10",
        "@radix-ui/react-accordion": "^1.1.2",
        "@radix-ui/react-checkbox": "^1.0.4",
        "@radix-ui/react-label": "^2.0.2",
        "@radix-ui/react-popover": "^1.1.2",
        "@radix-ui/react-slot": "^1.0.2",
        "@radix-ui/react-switch": "^1.0.3",
        "@radix-ui/react-tooltip": "^1.0.7",
        "@vscode/codicons": "^0.0.36",
        "@xyflow/react": "^12.1.4",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "dompurify": "^3.4.12",
        "highlight.js": "^11.10.0",
        "lucide-react": "^0.460.0",
        "marked": "^12.0.2",
        "marked-highlight": "^2.1.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "uuid": "^10.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "1.7.2",
        "@sourcegraph/tsconfig": "^4.0.1",
        "@types/node": "^20.11.30",
        "@types/react": "^18.2.66",
        "@types/react-dom": "^18.2.22",
        "@types/uuid": "^10.0.0",
        "@types/vscode": "^1.90.0",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^4.3.3",
        "@vscode/vsce": "^3.0.0",
        "archiver": "^7.0.1",
        "concurrently": "^9.2.1",
        "electron": "^39.8.10",
        "electron-builder": "^26.15.3",
        "electron-packager": "^17.1.2",
        "esbuild": "^0.27.2",
        "eslint": "^10.5.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "postcss": "^8.4.47",
        "postcss-nested": "^6.0.1",
        "tailwindcss": "^3.4.13",
        "tsx": "^4.22.4",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^7.3.1",
        "ws": "^8.21.1"
    }
}
